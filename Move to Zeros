class Solution:
    def moveZeroes(self, nums: List[int]) -> None:
        
        
        j = 0

        # Move non-zero elements to the front
        for i in range(len(nums)):
            if nums[i] != 0:
                nums[j] = nums[i]
                j += 1

        # Fill remaining positions with 0
        while j < len(nums):
            nums[j] = 0
            j += 1
