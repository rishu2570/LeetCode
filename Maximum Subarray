class Solution:
    def maxSubArray(self, nums):
        current_sum = nums[0]
        max_sum = nums[0]

        i = 1
        while i < len(nums):
            if current_sum + nums[i] > nums[i]:
                current_sum = current_sum + nums[i]
            else:
                current_sum = nums[i]

            if current_sum > max_sum:
                max_sum = current_sum

            i += 1

        return max_sum
