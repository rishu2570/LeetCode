class Solution:
    def productExceptSelf(self, nums):
        n = len(nums)

        answer = [0] * n

        # Store left products
        answer[0] = 1
        i = 1
        while i < n:
            answer[i] = answer[i - 1] * nums[i - 1]
            i += 1

        # Multiply with right products
        right = 1
        i = n - 1

        while i >= 0:
            answer[i] = answer[i] * right
            right = right * nums[i]
            i -= 1

        return answer
