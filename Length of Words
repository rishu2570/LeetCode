class Solution:
    def lengthOfLastWord(self, s: str) -> int:
        
        n = 0

        # Find length of string manually
        for ch in s:
            n += 1

        i = n - 1

        # Skip trailing spaces
        while i >= 0 and s[i] == ' ':
            i -= 1

        count = 0

        # Count last word
        while i >= 0 and s[i] != ' ':
            count += 1
            i -= 1

        return count
