class Solution:
    def maxProfit(self, prices: List[int]) -> int:
     
        buy = prices[0]
        profit = 0

        for i in range(1, len(prices)):
            if prices[i] < buy:
                buy = prices[i]
            else:
                current_profit = prices[i] - buy

                if current_profit > profit:
                    profit = current_profit

        return profit   
